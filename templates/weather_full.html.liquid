<div class="layout--stretch flex--col">
  <div class="title_bar">
    <span class="title">{{ settings.station_name | default("Weather") }}</span>
    {% if error %}
      <span class="label text--gray-50">stale data</span>
    {% endif %}
  </div>

  <div class="flex--col layout--center-x" style="flex: 1;">
    <span class="value value--xxxlarge">{{ data.temperature_f | round(0) }}°F</span>
    <span class="label">{{ data.sky_condition }}</span>
  </div>

  <div class="divider"></div>

  <div class="flex--row layout--space-between">
    <span class="label">Wind {{ data.wind_direction }} {{ data.wind_speed_mph | round(0) }} mph</span>
    {% if data.precip_chance_pct > 0 %}
      <span class="label">{{ data.precip_chance_pct | round(0) }}% precip</span>
    {% endif %}
  </div>

  {% if trip_decision %}
    <div class="divider"></div>
    <div class="flex--row layout--center-x">
      {% if trip_decision.go %}
        <span class="value value--large">GO</span>
      {% else %}
        <span class="value value--large text--gray-50">NO GO</span>
      {% endif %}
      <span class="label">{{ trip_decision.destination | default("") }}</span>
    </div>
  {% endif %}

  <div class="label text--gray-50" style="text-align: right;">
    {{ now.local }}
  </div>
</div>
